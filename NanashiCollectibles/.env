# Development: http://localhost:3001
# Production: Your Render.com URL (e.g., https://gamertavern.onrender.com)

# VITE_SOCKET_URL=https://server.nanashicollectibles.com
# VITE_API_BASE=https://server.nanashicollectibles.com

# Local dev
VITE_SOCKET_URL=http://localhost:3002
VITE_API_BASE=http://localhost:3002